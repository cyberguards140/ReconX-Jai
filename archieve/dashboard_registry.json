  "modals": [
    { "id": "deleteModal", "trigger": "Delete Project button" },
    { "id": "switchModal", "trigger": "Switch Project button" },
    { "id": "newModal", "trigger": "+ New Project button" }
  ],
  "api_bindings": [
    { "component": "runBtn", "future_api": "/api/scans/run_all" },
    { "component": "btn-run-nmap", "future_api": "/api/tools/nmap/run" },
    { "component": "btn-delete-project", "future_api": "/api/projects/delete" },
    { "component": "btn-new-project", "future_api": "/api/projects/create" },
    { "component": "btn-switch-project", "future_api": "/api/projects/switch" },
