    { "panel": "view-findings", "purpose": "findings-list" },
    { "panel": "view-history", "purpose": "execution-history" }
  ],
  "buttons": [
    { "id": "btn-delete-project", "label": "Delete Project", "action": "openModal('deleteModal')" },
