    { "id": "btn-run-nmap", "icon": "▶", "action": "runOnlyNmap()" },
    { "id": "btn-expand-nmap", "icon": "›", "action": "toggleExpand()" },
    { "id": "btn-copy-log", "label": "Copy Log", "action": "copyLog()" }
